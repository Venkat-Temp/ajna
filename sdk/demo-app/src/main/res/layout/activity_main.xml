<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#0A0A0A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mobile Intelligence Accelerator"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="36dp"/>

    <Button
        android:id="@+id/btn_signup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_signup"
        android:backgroundTint="@color/indigo"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_login"
        android:backgroundTint="@color/indigo"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_otp_fail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_otp_fail"
        android:backgroundTint="@color/danger"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_referral"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_referral"
        android:backgroundTint="@color/success"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_wallet_transfer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_wallet"
        android:backgroundTint="@color/warning"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_account_recovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_recovery"
        android:backgroundTint="@color/purple"/>

</LinearLayout>
