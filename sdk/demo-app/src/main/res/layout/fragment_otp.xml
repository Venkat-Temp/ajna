<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:minHeight="480dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐"
            android:textSize="44sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter Verification Code"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Sent to +91 ●●●● ●●567"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_attempt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_otp"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:hint="000000"
            android:textColorHint="#334155"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:background="@drawable/bg_input_field"
            android:inputType="number"
            android:maxLength="6"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:contentDescription="otp_input" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:text="✗  Incorrect code — try again"
            android:textColor="#FCA5A5"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:background="@drawable/bg_error_banner" />

        <TextView
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Verify Code"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:contentDescription="action_button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Resend code"
            android:textColor="#4F46E5"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
