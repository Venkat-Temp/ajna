<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Balance card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_balance_card"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Available Balance"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#EF4444"
                    android:visibility="gone"
                    android:background="@drawable/bg_badge_danger" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="₹47,250.00"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send Money"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To Account / UPI ID"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_recipient"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="14dp"
            android:hint="target@upi or account number"
            android:textColorHint="#334155"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:background="@drawable/bg_input_field"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:maxLines="1"
            android:contentDescription="recipient_input" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Amount (₹)"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_amount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="14dp"
            android:hint="0"
            android:textColorHint="#334155"
            android:textColor="#CBD5E1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_input_field"
            android:inputType="numberDecimal"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:contentDescription="amount_input" />

        <TextView
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Send Money"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_warning"
            android:contentDescription="action_button" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#475569"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
