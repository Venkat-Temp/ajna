<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:text="Join millions of users on PayAjna"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#4F46E5"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:background="@drawable/bg_badge_blue" />

        <TextView
            android:id="@+id/tv_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#EF4444"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:background="@drawable/bg_badge_danger" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="14dp"
            android:hint="Your full name"
            android:textColorHint="#334155"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:background="@drawable/bg_input_field"
            android:inputType="textPersonName"
            android:imeOptions="actionNext"
            android:maxLines="1"
            android:contentDescription="name_input" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_phone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="14dp"
            android:hint="+91 XXXXX XXXXX"
            android:textColorHint="#334155"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:background="@drawable/bg_input_field"
            android:inputType="phone"
            android:imeOptions="actionNext"
            android:maxLines="1"
            android:contentDescription="phone_input" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Referral Code (optional)"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_referral"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingHorizontal="14dp"
            android:hint="AJNA500"
            android:textColorHint="#334155"
            android:textColor="#059669"
            android:textSize="14sp"
            android:background="@drawable/bg_input_field"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:contentDescription="referral_input" />

        <TextView
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:contentDescription="action_button" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#475569"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
